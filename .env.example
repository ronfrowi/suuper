# ─── Next.js / Vercel ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Next.js — Scraper API (public, safe to expose) ─────────────────────────
NEXT_PUBLIC_SCRAPER_API_URL=https://your-railway-service.up.railway.app
# Must match SCRAPER_API_SECRET on the Railway service
NEXT_PUBLIC_SCRAPER_API_SECRET=your-random-secret-here

# ─── Scraper / Railway ────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
OPENAI_API_KEY=sk-...
PORT=3001
SCRAPER_API_SECRET=your-random-secret-here
TZ=America/Costa_Rica
NODE_ENV=development
